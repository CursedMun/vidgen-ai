generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Platform {
    instagram
    youtube
}

enum Model {
    veo
    chatgpt
}

enum WorkflowStatus {
    processing
    active
    deactivated
}

model Transcription {
    id           Int       @id @default(autoincrement())
    channelId    Int?      @map("channel_id")
    videoId      String?   @map("video_id")
    videoUrl     String    @map("video_url")
    thumbnailUrl String?   @map("thumbnail_url")
    status       String    @default("completed")
    errorMessage String?   @map("error_message")
    transcript   String?
    createdAt    DateTime  @default(now()) @map("created_at")
    updatedAt    DateTime  @updatedAt @map("updated_at")
    startedAt    DateTime? @map("started_at")
    completedAt  DateTime? @map("completed_at")

    @@map("transcriptions")
}

model Account {
    id        Int        @id @default(autoincrement())
    name      String
    platform  Platform
    jsonData  Json       @map("json_data")
    createdAt DateTime   @default(now()) @map("created_at")
    updatedAt DateTime   @updatedAt @map("updated_at")
    workflows Workflow[]
    posts     Post[]

    @@map("accounts")
}

enum AssetType {
    image
    audio
    video
}

model Asset {
    id        Int       @id @default(autoincrement())
    url       String
    type      AssetType
    metadata  Json
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    prompts   Prompt[]
    presets   Preset[]
    idea      Idea?     @relation(fields: [ideaId], references: [id])
    ideaId    Int?

    @@map("assets")
}

enum PromptType {
    video
    image
    audio
}

model Prompt {
    id           Int        @id @default(autoincrement())
    title        String
    content      String
    type         PromptType
    createdAt    DateTime   @default(now()) @map("created_at")
    updatedAt    DateTime   @updatedAt @map("updated_at")
    assets       Asset[]
    videoPresets Preset[]   @relation("video_prompts")
    audioPresets Preset[]   @relation("audio_prompts")
    imagePresets Preset[]   @relation("image_prompts")

    @@map("prompts")
}

model Preset {
    id            Int        @id @default(autoincrement())
    name          String
    description   String?
    videoPromptId Int?       @map("video_prompt_id")
    videoPrompt   Prompt?    @relation("video_prompts", fields: [videoPromptId], references: [id])
    audioPromptId Int?       @map("audio_prompt_id")
    audioPrompt   Prompt?    @relation("audio_prompts", fields: [audioPromptId], references: [id])
    imagePromptId Int?       @map("image_prompt_id")
    imagePrompt   Prompt?    @relation("image_prompts", fields: [imagePromptId], references: [id])
    createdAt     DateTime   @default(now()) @map("created_at")
    updatedAt     DateTime   @updatedAt @map("updated_at")
    workflows     Workflow[]
    assets        Asset[]

    @@map("presets")
}

enum SourceType {
    youtube
    rss
}

model Audio {
    id        Int      @id @default(autoincrement())
    title     String
    url       String
    duration  Int?
    genre     String?
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("audios")
}

model Source {
    id        Int        @id @default(autoincrement())
    name      String
    url       String
    type      SourceType
    createdAt DateTime   @default(now()) @map("created_at")
    updatedAt DateTime   @updatedAt @map("updated_at")
    workflows Workflow[]
    ideas     Idea[]

    @@map("sources")
}

model Idea {
    id          Int      @id @default(autoincrement())
    url         String   @map("url")
    description String
    sourceId    Int
    source      Source   @relation(fields: [sourceId], references: [id])
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")
    videos      Video[]
    assets      Asset[]

    @@map("ideas")
}

enum WorkflowType {
    video_ideas_fetching
    video_generation
    video_publish_with_sound
    video_publish
    image_generation
    image_publish
}

model Workflow {
    id              Int            @id @default(autoincrement())
    title           String
    description     String?
    //example 1h, 6h, 10m, 1w, 1m
    interval        String
    jobsPerInterval Int            @default(0) @map("jobs_per_interval")
    type            WorkflowType   @map("workflow_type")
    model           Model          @default(chatgpt)
    status          WorkflowStatus @default(active)
    sourceId        Int            @map("source_id")
    lastRunAt       DateTime?      @map("last_run_at")
    nextRunAt       DateTime?      @map("next_run_at")
    source          Source         @relation(fields: [sourceId], references: [id])
    presetId        Int?           @map("preset_id")
    preset          Preset?        @relation(fields: [presetId], references: [id])
    accounts        Account[]
    workflowRuns    WorkflowRun[]

    createdAt    DateTime      @default(now()) @map("created_at")
    updatedAt    DateTime      @updatedAt @map("updated_at")
    workflowJobs WorkflowJob[]

    @@map("workflows")
}

enum WorkflowJobStatus {
    processing
    pending
    completed
    failed
}

model WorkflowRun {
    id            Int         @id @default(autoincrement())
    workflowJobId Int         @unique @map("workflow_job_id")
    result        Json
    error         Json?
    startedAt     DateTime    @default(now()) @map("started_at")
    completedAt   DateTime?   @map("completed_at")
    workflowJob   WorkflowJob @relation(fields: [workflowJobId], references: [id])
    workflow      Workflow    @relation(fields: [workflowId], references: [id])
    workflowId    Int

    @@map("workflow_runs")
}

model WorkflowJob {
    id            Int               @id @default(autoincrement())
    workflowRunId Int?              @unique @map("workflow_run_id")
    data          Json
    status        WorkflowJobStatus @default(pending)
    executedAt    DateTime?         @map("executed_at")
    completedAt   DateTime?         @map("completed_at")
    createdAt     DateTime          @default(now()) @map("created_at")
    updatedAt     DateTime          @updatedAt @map("updated_at")
    workflowRun   WorkflowRun?
    workflow      Workflow          @relation(fields: [workflowId], references: [id])
    workflowId    Int
    videos        Video[]

    @@map("workflow_jobs")
}

model WorkflowJobsPerDay {
    id        Int          @id @default(autoincrement())
    type      WorkflowType @unique
    count     Int          @map("count")
    createdAt DateTime     @default(now()) @map("created_at")
    updatedAt DateTime     @updatedAt @map("updated_at")

    @@map("workflow_jobs_per_day")
}

model Video {
    id            Int         @id @default(autoincrement())
    path          String
    ideaId        Int         @map("idea_id")
    idea          Idea        @relation(fields: [ideaId], references: [id])
    workflowJobId Int         @map("workflow_job_id")
    workflowJob   WorkflowJob @relation(fields: [workflowJobId], references: [id])
    createdAt     DateTime    @default(now()) @map("created_at")
    updatedAt     DateTime    @updatedAt @map("updated_at")
    posts         Post[]

    @@map("videos")
}

model Post {
    id          Int      @id @default(autoincrement())
    videoId     Int?     @map("video_id")
    video       Video?   @relation(fields: [videoId], references: [id])
    description String?
    accountId   Int      @map("account_id")
    account     Account  @relation(fields: [accountId], references: [id])
    externalId  String?  @map("external_id")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    @@map("posts")
}
